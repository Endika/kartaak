{
  "name": "kartaak",
  "private": true,
  "version": "0.0.5",
  "type": "module",
  "description": "Flashcard study app with AI-generated cards, offline-first PWA",
  "license": "MIT",
  "author": "Endika Iglesias",
  "homepage": "https://endika.github.io/kartaak/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Endika/kartaak.git"
  },
